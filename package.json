{
  "name": "@finografic/design-system-workspace",
  "private": true,
  "type": "module",
  "description": "Workspace root — see packages/ for publishable packages.",
  "scripts": {
    "·········· DEV": "·······················································",
    "dev": "pnpm --filter @finografic/design-system dev",
    "watch": "pnpm --filter @finografic/design-system watch",
    "dev:icons": "pnpm --filter @finografic/icons dev",
    "·········· BUILD": "·····················································",
    "build": "pnpm --filter @finografic/design-system build",
    "build:icons": "pnpm --filter @finografic/icons build",
    "build:all": "pnpm build:icons && pnpm build",
    "·········· ICONS": "·····················································",
    "icons": "pnpm --filter @finografic/icons icons:config",
    "icons:generate": "pnpm --filter @finografic/icons build",
    "·········· TYPECHECK": "·················································",
    "typecheck": "pnpm -r typecheck",
    "typecheck:ds": "pnpm --filter @finografic/design-system typecheck",
    "typecheck:icons": "pnpm --filter @finografic/icons typecheck",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "·········· FORMATTING": "················································",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --detach",
    "clean:dry": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --dry-run",
    "·········· PUBLISH": "···················································",
    "release:patch": "tsx scripts/release.ts patch",
    "release:minor": "tsx scripts/release.ts minor",
    "release:major": "tsx scripts/release.ts major",
    "·········· PACKAGES": "··················································",
    "update:project-scripts": "pnpm update @finografic/project-scripts --latest",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest && pnpm update oxfmt --latest && pnpm update oxlint --latest",
    "upgrade:deps:all": "pnpm update --latest",
    "·········· UTILS": "·····················································",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "tsc:scripts": "tsc -p tsconfig.scripts.json",
    "postinstall": "husky",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@finografic/oxc-config": "^2.3.5",
    "@finografic/project-scripts": "1.3.3",
    "@types/node": "24",
    "concurrently": "^9.2.1",
    "eslint-plugin-markdownlint": "^0.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
