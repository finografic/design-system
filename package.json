{
  "name": "@finografic/design-system",
  "type": "module",
  "version": "0.0.1",
  "description": "Token-driven design system built on Ark UI and Panda CSS.",
  "homepage": "https://github.com/finografic/design-system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/design-system.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/design-system/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com"
  },
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./recipes": {
      "types": "./dist/recipes/index.d.ts",
      "import": "./dist/recipes/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./styles/reset.css": "./src/styles/reset.css",
    "./styles/keyframes.css": "./src/styles/keyframes.css",
    "./styles/global.css": "./src/styles/global.css",
    "./panda.preset": {
      "types": "./dist/panda.preset.d.ts",
      "import": "./dist/panda.preset.js"
    }
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "·········· LINTING": "················································",
    "lint": "eslint .",
    "lint.fix": "eslint . --fix",
    "·········· FORMATTING": "················································",
    "format": "dprint fmt **/*.md --diff",
    "format.check": "dprint check",
    "·········· UTILS": "·····················································",
    "panda:codegen": "panda codegen",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ark-ui/react": "^5.11.0",
    "@finografic/dprint-config": "0.12.4",
    "@pandacss/dev": "^0.53.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@stylistic/eslint-plugin": "^4.4.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.33.0",
    "eslint-plugin-markdownlint": "^0.9.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "8.5.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.55.0"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
