{
  "name": "@finografic/design-system",
  "type": "module",
  "version": "0.0.1",
  "description": "Token-driven design system built on Ark UI and Panda CSS.",
  "homepage": "https://github.com/finografic/design-system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/design-system.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/design-system/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com"
  },
  "private": true,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.mts",
      "import": "./dist/tokens/index.mjs"
    },
    "./recipes": {
      "types": "./dist/recipes/index.d.mts",
      "import": "./dist/recipes/index.mjs"
    },
    "./components": {
      "types": "./dist/components/index.d.mts",
      "import": "./dist/components/index.mjs"
    },
    "./styles/reset.css": "./src/styles/reset.css",
    "./styles/keyframes.css": "./src/styles/keyframes.css",
    "./styles/global.css": "./src/styles/global.css",
    "./grid": {
      "types": "./dist/grid/index.d.mts",
      "import": "./dist/grid/index.mjs"
    },
    "./grid/grid.css": "./src/grid/grid.css",
    "./forms": {
      "types": "./dist/forms/index.d.mts",
      "import": "./dist/forms/index.mjs"
    },
    "./forms/forms.css": "./src/forms/forms.css",
    "./forms/primitives": {
      "types": "./dist/forms/primitives.d.mts",
      "import": "./dist/forms/primitives.mjs"
    },
    "./viewport": {
      "types": "./dist/viewport/index.d.mts",
      "import": "./dist/viewport/index.mjs"
    },
    "./icons": {
      "types": "./dist/icons/index.d.mts",
      "import": "./dist/icons/index.mjs"
    },
    "./palette/colors.base": {
      "types": "./dist/palette/colors.palette.d.mts",
      "import": "./dist/palette/colors.palette.mjs"
    },
    "./panda.preset": {
      "types": "./dist/panda.preset.d.mts",
      "import": "./dist/panda.preset.mjs"
    }
  },
  "files": [
    "dist",
    "src/styles",
    "src/grid",
    "src/forms"
  ],
  "scripts": {
    "prepare": "panda codegen",
    "build": "panda cssgen && tsdown",
    "dev": "tsdown --watch --no-clean",
    "·········· LINTING": "················································",
    "lint": "eslint .",
    "lint.fix": "eslint . --fix",
    "·········· FORMATTING": "················································",
    "format": "dprint fmt **/*.md --diff",
    "format.check": "dprint check",
    "·········· CLEAN": "·····················································",
    "clean": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --detach",
    "clean.dry": "pnpm --package=@finografic/project-scripts dlx purge-builds --recursive --dry-run",
    "update.project-scripts": "pnpm update @finografic/project-scripts --latest --recursive",
    "·········· UTILS": "·····················································",
    "panda:studio": "panda studio",
    "panda:codegen": "panda codegen",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ark-ui/react": "^5.11.0",
    "@finografic/dprint-config": "0.12.4",
    "@pandacss/dev": "^0.53.1",
    "lucide-react": "^0.564.0",
    "match-sorter": "8.2.0",
    "react-hook-form": "7.71.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@finografic/project-scripts": "8.12.0",
    "@pandacss/studio": "1.8.2",
    "@stylistic/eslint-plugin": "^4.4.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.33.0",
    "eslint-plugin-markdownlint": "^0.9.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "17.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.55.0"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "7.71.1"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    }
  }
}
