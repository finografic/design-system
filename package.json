{
  "name": "@finografic/design-system",
  "type": "module",
  "version": "0.0.1",
  "description": "Token-driven design system built on Ark UI and Panda CSS.",
  "homepage": "https://github.com/finografic/design-system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/design-system.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/design-system/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com"
  },
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./recipes": {
      "types": "./dist/recipes/index.d.ts",
      "import": "./dist/recipes/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./styles/reset.css": "./src/styles/reset.css",
    "./styles/keyframes.css": "./src/styles/keyframes.css",
    "./styles/global.css": "./src/styles/global.css",
    "./panda.preset": {
      "types": "./dist/panda.preset.d.ts",
      "import": "./dist/panda.preset.js"
    }
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "panda:codegen": "panda codegen",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ark-ui/react": "^5.11.0",
    "@pandacss/dev": "^0.53.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "8.5.1",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
