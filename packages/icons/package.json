{
  "name": "@finografic/icons",
  "version": "1.10.0",
  "private": false,
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "·········· ICONS": "·····················································",
    "icons.config": "concurrently -n \"server,config\" -c \"cyan,green\" \"tsx server/icons-server.ts\" \"lucide-manager\"",
    "icons.server": "tsx server/icons-server.ts",
    "·········· BUILD": "·····················································",
    "build": "tsx scripts/generate.ts && tsdown",
    "dev": "tsdown --watch --no-clean",
    "typecheck": "tsc --noEmit",
    "·········· PACKAGES": "···················································",
    "lucide-manager": "pnpm update @finografic/lucide-manager --latest"
  },
  "dependencies": {
    "lucide-react": "^0.564.0"
  },
  "devDependencies": {
    "@finografic/lucide-manager": "0.6.2",
    "@finografic/project-scripts": "1.3.3",
    "@hono/node-server": "1.19.9",
    "@types/react": "^18.3.12",
    "concurrently": "9.2.0",
    "hono": "^4.11.9",
    "picocolors": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsdown": "^0.21.2",
    "tsx": "4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  }
}
